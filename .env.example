# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bet360

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Redis
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLIC_KEY=pk_test_your_key

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Sports API
SPORTS_API_KEY=your_sports_api_key
SPORTS_API_URL=https://api.sportsdata.io

# Casino API
CASINO_API_KEY=your_casino_api_key
CASINO_API_URL=https://api.casinoapi.com

# Frontend
FRONTEND_URL=http://localhost:3000

# Admin Settings
ADMIN_EMAIL=admin@bet360.com
ADMIN_PASSWORD=change_me
